{
  "expo": {
    "name": "tar",
    "slug": "tar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tarapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tarfw.tar"
    },
    "android": {
      "package": "com.tarfw.tar",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0C5027",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0C5027",
          "dark": {
            "backgroundColor": "#0C5027"
          }
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosClientId": "291840005173-dqgbihtc6e9q9rq94r17la3d213imb2t.apps.googleusercontent.com",
          "androidClientId": "291840005173-dqgbihtc6e9q9rq94r17la3d213imb2t.apps.googleusercontent.com",
          "scopes": [
            "profile",
            "email"
          ],
          "iosUrlScheme": "com.googleusercontent.apps.291840005173-dqgbihtc6e9q9rq94r17la3d213imb2t",
          "webClientId": "291840005173-dqgbihtc6e9q9rq94r17la3d213imb2t.apps.googleusercontent.com"
        }
      ],
      "expo-asset",
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cc676e19-e199-4fba-aeac-a564814a1b48"
      }
    },
    "owner": "tarfw"
  }
}
